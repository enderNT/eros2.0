# Anthropic
ANTHROPIC_API_KEY=

# Modelos (ver glosario/ADRs)
MODEL_SUPERVISOR=claude-haiku-4-5
MODEL_CRISIS=claude-haiku-4-5
MODEL_AGENTE=claude-opus-4-8

# Loop del agente principal (Claude Opus 4.8)
AGENT_MAX_TOKENS=4096
AGENT_THINKING_TYPE=adaptive
AGENT_THINKING_DISPLAY=omitted
AGENT_EFFORT=high

# Memoria conversacional
HISTORY_WINDOW=10
HISTORY_COMPACT_LIMIT=16
HISTORY_OVERLAP=1

# Postgres para memoria + logger. docker compose lo define apuntando al servicio postgres.
DATABASE_URL=

# Canal (Chatwoot) — para enviar respuestas y leer/escribir el atributo bot_activo
CHATWOOT_BASE_URL=
CHATWOOT_API_TOKEN=

# Agendamiento (Calendly Scheduling API)
CALENDLY_TOKEN=

LOG_LEVEL=INFO
