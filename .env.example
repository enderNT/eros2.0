# Anthropic
ANTHROPIC_API_KEY=

# Modelos (ver glosario/ADRs)
MODEL_SUPERVISOR=claude-haiku-4-5
MODEL_CRISIS=claude-haiku-4-5
MODEL_AGENTE=claude-opus-4-8

# Memoria corta (checkpointer). En Docker apuntar a un volumen, p.ej. /data/checkpoints.sqlite
CHECKPOINT_DB_PATH=data/checkpoints.sqlite
HISTORY_WINDOW=10

# Logger LLM. docker compose lo define apuntando al servicio postgres.
DATABASE_URL=

# Canal (Chatwoot) — para enviar respuestas y leer/escribir el atributo bot_activo
CHATWOOT_BASE_URL=
CHATWOOT_API_TOKEN=

# Agendamiento (Calendly Scheduling API)
CALENDLY_TOKEN=

LOG_LEVEL=INFO
